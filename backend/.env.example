# Server
PORT=3000

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# ChromaDB
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=rag_documents

# OpenAI
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# Alfresco Content Services
ALFRESCO_BASE_URL=http://localhost:8080
ALFRESCO_USERNAME=admin
ALFRESCO_PASSWORD=admin

# RAG tuning
# Cosine distance threshold (0-2, lower = more similar). Documents with
# best-match distance above this value are considered irrelevant.
RELEVANCE_THRESHOLD=0.7
# How many chunks to fetch from ChromaDB for hybrid re-ranking
SIMILARITY_TOP_K=20
# How many re-ranked chunks to pass as context to the LLM
CONTEXT_TOP_K=5
